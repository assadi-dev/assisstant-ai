# ─────────────────────────────────────────────────────────────────────────────
# Assistant AI — variables d'environnement (PRODUCTION)
#
# Copier ce fichier en `.env.production` (ou configurer ces variables dans
# le dashboard de l'hébergeur : Vercel, Railway, Docker, etc.) puis remplacer
# chaque placeholder par une vraie valeur.
#
#   cp .env.example .env.production
#
# ⚠️ Ne JAMAIS commiter de secret réel. Ce fichier ne contient que des exemples.
# ─────────────────────────────────────────────────────────────────────────────

# Environnement Node (production en déploiement)
NODE_ENV=production

# ── Base de données — PostgreSQL (Drizzle ORM) ──────────────────────────────
# URL de la base managée en production (Neon, Supabase, RDS, Railway…).
# Activer SSL si l'hébergeur l'exige : ?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/assistant_ai?sslmode=require"

# ── Better Auth — https://better-auth.com ───────────────────────────────────
# Secret long et aléatoire. Générer avec : openssl rand -base64 32
BETTER_AUTH_SECRET="GENERER_UNE_CHAINE_ALEATOIRE_LONGUE"
# URL publique HTTPS de l'application en production (sans slash final)
BETTER_AUTH_URL="https://votre-domaine.com"

# ── Google OAuth (login Google) ─────────────────────────────────────────────
# console.cloud.google.com > APIs & Services > Credentials > OAuth 2.0
# Ajouter l'URI de redirection prod : https://votre-domaine.com/api/auth/callback/google
GOOGLE_CLIENT_ID="VOTRE_GOOGLE_CLIENT_ID.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="VOTRE_GOOGLE_CLIENT_SECRET"

# ── Provider LLM (chat) ─────────────────────────────────────────────────────
# En production, préférer un provider hébergé (pas Ollama local).
# Valeurs possibles : anthropic | openai | mistral | ollama
AI_PROVIDER=anthropic

# Anthropic (Claude) — recommandé pour la prod
ANTHROPIC_API_KEY="sk-ant-VOTRE_CLE_API"
ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI — si AI_PROVIDER=openai
# OPENAI_API_KEY="sk-VOTRE_CLE_API"
# OPENAI_MODEL=gpt-4o

# Mistral — si AI_PROVIDER=mistral
# MISTRAL_API_KEY="VOTRE_CLE_API"
# MISTRAL_MODEL=mistral-large-latest

# Ollama — uniquement si vous hébergez un serveur Ollama accessible en prod
# OLLAMA_BASE_URL=https://ollama.votre-domaine.com/v1
# OLLAMA_MODEL=llama3.2:latest
